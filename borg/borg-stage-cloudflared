#!/bin/sh
# Stages /etc/cloudflared into a caller-owned directory for Borg backups.
# Invoked via: sudo -n /usr/local/sbin/borg-stage-cloudflared DEST
# DEST must resolve to .../tmp.*/etc-cloudflared under /tmp or /var/tmp only.

set -e

if [ "$#" -ne 1 ] || [ -z "$1" ]; then
    echo "usage: borg-stage-cloudflared dest_dir" >&2
    exit 1
fi

if ! command -v readlink >/dev/null 2>&1; then
    echo "borg-stage-cloudflared: readlink not found" >&2
    exit 1
fi

dest="$(readlink -nf "$1" 2>/dev/null || true)"
case "$dest" in
/tmp/tmp.*/etc-cloudflared | /var/tmp/tmp.*/etc-cloudflared) ;;
*)
    echo "borg-stage-cloudflared: refusing dest (not .../tmp.*/etc-cloudflared under /tmp or /var/tmp): $1" >&2
    exit 1
    ;;
esac

mkdir -p "$dest"
/bin/cp -a /etc/cloudflared/. "$dest/"
# Borg runs as the invoking user (not root); tunnels use mode 0600 files.
if [ -n "$SUDO_UID" ]; then
    _gid="${SUDO_GID:-$(getent passwd "$SUDO_UID" | cut -d: -f4)}"
    chown -R "$SUDO_UID:${_gid}" "$dest"
fi

